# Base directories
export LOCAL_HOME="$HOME/.local"
export BREW_HOME="/opt/homebrew"
export JAVA_HOME="/usr/lib/jvm/java-21-openjdk-amd64"

# Language environments
export SDKMAN_DIR="$HOME/.sdkman"
export BUN_INSTALL="$HOME/.bun"
export XDG_CONFIG_HOME="$HOME/.config"
export EZA_CONFIG_DIR="$HOME/.config/eza"

# Go configuration
export GOPATH="$HOME/go"
export GOBIN="$BREW_HOME/bin"
export GOINSECURE="bitbucket.org/*"
export GOPRIVATE="github.com/*"
export GONOSUMDB="github.com/*"
export GONOPROXY="github.com/*"

# Tools
export MYSQL_PATH="$BREW_HOME/opt/mysql-client"
export EZA_CONFIG_DIR="$HOME/.config/eza"
export PHP_INI_SCAN_DIR="$HOME/.config/herd-lite/bin:$PHP_INI_SCAN_DIR"

# FZF / Enhancd
export FZF_DEFAULT_OPTS="
  --height 40% 
  --layout=reverse 
  --border --inline-info
  --preview-window=right:60%:wrap 
  --preview '
    if [ -d {} ]; then
      eza -aal --tree --level=2 --color=always {}
    else
      bat --style=numbers --color=always {}
    fi
  '
"
export FZF_DEFAULT_COMMAND="rg --files"

# PATH
path+=(
  "$LOCAL_HOME/bin"
  "$BREW_HOME/bin"
  "$BREW_HOME/opt/libpq/bin"
  "$BUN_INSTALL/bin"
  "$HOME/.cargo/bin"
  "$JAVA_HOME/bin"
  "$HOME/.config/herd-lite/bin"
  "$GOPATH/bin"
  "/usr/local/go/bin"
  "$HOME/.console-ninja/.bin"
  "$MYSQL_PATH/bin"
  "$SDKMAN_DIR/bin"
)

export PATH

# pnpm
export PNPM_HOME="$LOCAL_HOME/share/pnpm"
path+=("$PNPM_HOME")

# Brew
eval "$($BREW_HOME/bin/brew shellenv)"
