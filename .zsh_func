# ─────────────────────────────────────────────────────────────
# AI CONFIG
# ─────────────────────────────────────────────────────────────

AICHAT_SYSTEM_PROMPT_FILE="$HOME/.config/aichat/system_prompt.md"

# ===== CLOUD MODELS =====
AI_CLOUD_FAST="groq:qwen/qwen3-32b"
AI_CLOUD_SMART="groq:llama-3.3-70b-versatile"
AI_CLOUD_PLAN="gemini:gemini-2.5-flash"

# ===== LOCAL MODELS =====
AI_LOCAL_GENERAL="ollama:qwen3.5:9b"
AI_LOCAL_CODE="ollama:qwen2.5-coder:7b"
AI_LOCAL_LIGHT="ollama:gemma4:e4b"

# ===== DEFAULTS =====
AI_DEFAULT_TIMEOUT=120
AI_MAX_RETRIES=1

# ─────────────────────────────────────────────────────────────
# PROMPTS
# ─────────────────────────────────────────────────────────────

AI_CODE_PROMPT="You are a senior expert coding assistant.
Focus: clean architecture, performance, concurrency safety.
Return:
- concise production-ready code
- minimal comments
- no long explanation unless asked
- maximum 5 sentences
Task:"

AI_REFACTOR_PROMPT="Refactor for clean architecture and performance. Code:"

AI_TEST_PROMPT="Write unit tests covering edge cases. Code:"

AI_REVIEW_PROMPT="You are a senior software engineer doing strict code review.
Find bugs, race conditions, performance issues, security risks, and bad practices.
Give concise actionable feedback in bullet points. Code:"

# ─────────────────────────────────────────────────────────────
# TASK REGISTRY
# ─────────────────────────────────────────────────────────────
#
# format:
# TASK|PRIMARY|FALLBACK|PROMPT_VAR|USE_SYS
#

_AI_TASKS=$(cat <<EOF
code|$AI_CLOUD_SMART|$AI_LOCAL_CODE|AI_CODE_PROMPT|0
refactor|$AI_CLOUD_SMART|$AI_LOCAL_CODE|AI_REFACTOR_PROMPT|0
test|$AI_CLOUD_FAST|$AI_LOCAL_CODE|AI_TEST_PROMPT|0
review|$AI_CLOUD_FAST|$AI_LOCAL_CODE|AI_REVIEW_PROMPT|1
plan|$AI_CLOUD_PLAN|$AI_LOCAL_GENERAL||1
think|$AI_CLOUD_FAST|$AI_LOCAL_GENERAL||1
offline|$AI_LOCAL_CODE|$AI_LOCAL_LIGHT|AI_CODE_PROMPT|0
EOF
)

# ─────────────────────────────────────────────────────────────
# INTERNAL HELPERS
# ─────────────────────────────────────────────────────────────

_ai_sys() {
  [[ -f "$AICHAT_SYSTEM_PROMPT_FILE" ]] \
    && cat "$AICHAT_SYSTEM_PROMPT_FILE"
}

_ai_input() {
  local args="$*"

  if [[ ! -t 0 ]]; then
    local piped
    piped="$(cat)"
    printf "%s\n%s" "$args" "$piped"
  else
    printf "%s" "$args"
  fi
}

_ai_lookup_task() {
  local task="$1"
  echo "$_AI_TASKS" | grep "^${task}|"
}

_ai_extract_field() {
  local line="$1"
  local field="$2"

  echo "$line" | cut -d'|' -f"$field"
}

# ─────────────────────────────────────────────────────────────
# CORE RUNNER
# ─────────────────────────────────────────────────────────────

_ai_run() {
  local primary="$1"
  local fallback="$2"
  local use_sys="$3"

  shift 3

  local prompt="$*"

  local sys_prompt=""
  (( use_sys )) && sys_prompt="$(_ai_sys)"

  local cmd=(
    aichat
    -m "$primary"
    "$prompt"
  )

  echo "  [ai] primary: $primary" >&2

  if (( use_sys )); then
    AICHAT_SYSTEM_PROMPT="$sys_prompt" "${cmd[@]}" \
      && return 0
  else
    "${cmd[@]}" \
      && return 0
  fi

  echo "  [ai] fallback: $fallback" >&2

  cmd=(
    aichat
    -m "$fallback"
    "$prompt"
  )

  if (( use_sys )); then
    AICHAT_SYSTEM_PROMPT="$sys_prompt" "${cmd[@]}"
  else
    "${cmd[@]}"
  fi
}

# ─────────────────────────────────────────────────────────────
# TASK EXECUTOR
# ─────────────────────────────────────────────────────────────

_ai_task() {
  local task="$1"
  shift

  local line
  line="$(_ai_lookup_task "$task")"

  [[ -z "$line" ]] && {
    echo "Unknown AI task: $task" >&2
    return 1
  }

  local primary fallback prompt_var use_sys

  primary="$(_ai_extract_field "$line" 2)"
  fallback="$(_ai_extract_field "$line" 3)"
  prompt_var="$(_ai_extract_field "$line" 4)"
  use_sys="$(_ai_extract_field "$line" 5)"

  local input
  input="$(_ai_input "$@")"

  local prompt=""
  [[ -n "$prompt_var" ]] && prompt="${(P)prompt_var}"$'\n'

  _ai_run \
    "$primary" \
    "$fallback" \
    "$use_sys" \
    "${prompt}${input}"
}

# ─────────────────────────────────────────────────────────────
# PUBLIC COMMANDS
# ─────────────────────────────────────────────────────────────

aicode()      { _ai_task code "$@"; }
airefactor()  { _ai_task refactor "$@"; }
aitest()      { _ai_task test "$@"; }
aireview()    { _ai_task review "$@"; }
aiplan()      { _ai_task plan "$@"; }
aithink()     { _ai_task think "$@"; }
aioffline()   { _ai_task offline "$@"; }

# ─────────────────────────────────────────────────────────────
# FILE SHORTCUTS
# ─────────────────────────────────────────────────────────────

_ai_file_task() {
  local task="$1"
  local file="$2"

  [[ ! -f "$file" ]] && {
    echo "File not found: $file" >&2
    return 1
  }

  _ai_task "$task" "$(cat "$file")"
}

aicode_file()      { _ai_file_task code "$1"; }
aireview_file()    { _ai_file_task review "$1"; }
airefactor_file()  { _ai_file_task refactor "$1"; }
aitest_file()      { _ai_file_task test "$1"; }

# ─────────────────────────────────────────────────────────────
# END
# ─────────────────────────────────────────────────────────────

# Dynamic file/folder view using eza - switches between list and grid based on item count
# Input: $1 - directory path (optional, defaults to current directory)
# Output: List view for <=10 items, grid view for >10 items
_dynamic_view() {
    local dir_path=${1:-.}
    local item_count

    if [[ ! -d "$dir_path" ]]; then
        echo "Error: '$dir_path' is not a valid directory."
        return 1
    fi

    item_count=$(eza -a "$dir_path" | head -n 11 | wc -l)

    local -a base_flags=(
        --icons
        --color=auto
        --sort=name
        --group-directories-first
        --color-scale=all
        -aahlo
    )

    if (( item_count <= 10 )); then
        eza "${base_flags[@]}" -m "$dir_path"
    else
        eza "${base_flags[@]}" -Gm "$dir_path"
    fi
}

# Interactive alias search using fzf
# Input: None (displays all aliases for selection)
# Output: Executes the selected alias command
_alias_search() {
    local selection=$(alias | fzf --preview "echo {}")
    (eval "$selection")
}

# Safely clear/truncate a file with confirmation prompt
# Input: $1 - file path to clear
# Output: Clears the file content or aborts based on user confirmation
_clearfile() {
    echo "Are you sure you want to clear $1? (y/n)"
    read choice
    if [[ "$choice" == "y" ]]; then
        sudo truncate -s 0 "$1"
        echo "File $1 cleared."
    else
        echo "Aborted."
    fi
}

# Safely delete a directory with confirmation prompt
# Input: $1 - directory name/path to delete
# Output: Removes directory recursively or aborts based on user confirmation
_deldir() {
    #-- check if param1 provided as a directory_name?
    if [[ -z "$1" ]]; then
        echo "Usage: deldir <directory_name>"
        return 1
    fi

    #-- check if the directory exists
    if [[ ! -d "$1" ]]; then
        echo "Error: Directory '$1' does not exist."
        return 1
    fi

    #-- confirm deletion
    echo -n "Are you sure you want to delete the directory '$1'? (y/N): "
    read confirm
    case "$confirm" in
        [yY][eE][sS]|[yY])  # Accept 'yes', 'Yes', 'Y', 'y'
            rm -r "$1" && echo "Directory '$1' has been deleted."
            ;;
        *)
            echo "Deletion canceled."
            ;;
    esac
}

# Delete a file with interactive confirmation
# Input: $1 - file path to delete
# Output: Removes file with confirmation prompt
_delfile() {
    rm -i "$1" && echo "File $1 deleted.";
}

# This functions enhance default 'cd' command
cd() {
  if [[ $# -gt 0 ]]; then
    builtin cd "$@"
    clear
    _dynamic_view
    return
  fi

  # Interactive mode
  local dir
  dir=$(fd -t d --max-depth 1 --strip-cwd-prefix 2>/dev/null \
    | fzf \
        --prompt="📁 Select directory > " \
        --height 40% \
        --layout=reverse \
        --border \
        --preview '
          if [ "{}" = ".." ]; then
            eza --icons -lah --color=always ..
          else
            eza --icons -lah --color=always {}
          fi
        '
  ) || return

  builtin cd "$dir"
  clear
  _dynamic_view
}

# This functions will list all of parent folder for easy navigation
_dir_parent() {
  local dir=$(dirname "$PWD")
  local selected

  selected=$(while true; do
      echo "$dir"
      [[ "$dir" == "/" ]] && break
      dir=$(dirname "$dir")
    done | fzf \
        --prompt="⬆ jump to parent > " \
        --preview 'eza --icons -lah --color=always {}') || return

  cd "$selected"
}

# Run a MySQL Docker container with predefined settings
# Input: $1 - MySQL version (e.g., '8.0', 'latest')
# Output: Starts MySQL container named 'mysql-local' on port 3306
_docker_run_mysql() {
    #-- check if param1 provided as mysql_version?
    if [[ -z "$1" ]]; then
        echo "Usage: dmysql <mysql_version>"
        echo "example: dmysql 8.0 | dmysql latest"
        return 1
    fi

    docker run --name mysql-local -e MYSQL_ROOT_PASSWORD=root -e MYSQL_USER=localuser -e MYSQL_PASSWORD=test1234 -p 3306:3306 -d mysql:$1
}

# Run a PostgreSQL Docker container with predefined settings
# Input: $1 - PostgreSQL version (e.g., '13', 'latest')
# Output: Starts PostgreSQL container named 'postgresql-local' on port 5432
_docker_run_postgresql() {
    #-- check if param1 provided as postgresql_version?
    if [[ -z "$1" ]]; then
        echo "Usage: dpostgresql <postgresql_version>"
        echo "example: dpostgresql 8.0 | dpostgresql latest"
        return 1
    fi

    docker run --name postgresql-local -e POSTGRESQL_USERNAME=postgres -e POSTGRESQL_PASSWORD=test1234 -p 5432:5432 -v postgres_data:/bitnami/postgresql -d bitnami/postgresql:$1
}

# Interactive git branch selector with preview using fzf
# Input: None (shows all git branches)
# Output: Displays branch list with git log preview for selection
_fzf_git_branch() {
  git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/heads refs/remotes \
  | fzf \
    --preview '
      git log --graph --oneline --decorate --color=always -n 30 {} \
      | bat --color=always --style=plain --paging=never
    ' \
    --bind 'ctrl-d:preview:git log -p -n 5 {} | delta' \
    --bind 'ctrl-s:preview:git show {} | delta' \
    --preview-window=right:70%
}

# Generate new project scaffolding for various technologies
# Input: $1 - technology type (laravel|vite|react), $2 - folder name
# Output: Creates new project in specified folder with chosen technology
_gen() {
    if [ $# -ne 2 ]; then
        echo "Usage: gen <laravel|vite|react|golang> <folder_name>";
        return 1;
    fi;

    # Read parameters
    TECH_TYPE=$1
    FOLDER_NAME=$2

    # Main logic using case statement
    case "$TECH_TYPE" in
    laravel)
        echo "Initializing Laravel project in folder: $FOLDER_NAME"
        laravel new "$FOLDER_NAME"
        ;;
    vite)
        echo "Initializing Vite project in folder: $FOLDER_NAME"
        npm create vite@latest "$FOLDER_NAME"
        ;;
    react)
        echo "Initializing React Native project in folder: $FOLDER_NAME"
        mkdir -p "$FOLDER_NAME" && cd "$FOLDER_NAME" || return 1
        npx create-expo-app@latest .
        ;;
    golang)
        echo "Initializing Golang project in folder: $FOLDER_NAME"
        mkdir -p "$FOLDER_NAME" && cd "$FOLDER_NAME" || return 1

        go mod init "github.com/rhewin/$FOLDER_NAME"

	mkdir -p cmd/api
cat <<EOF > cmd/api/main.go
package main

import (
	"log"
	"net/http"

	"github.com/go-chi/chi/v5"
)
func main() {
	r := chi.NewRouter()
	r.Get("/health", func(w http.ResponseWriter, r *http.Request) {
		w.Write([]byte("ok"))
	})
	log.Fatal(http.ListenAndServe(":8080", r))
}
EOF

    	go mod tidy
        ;;
	
    *)
        echo "Error: Unsupported tech type '$TECH_TYPE'"
        echo "Supported types are: laravel, vite"
        return 1
        ;;
    esac
}

# An enhancement version of git checkout
_git_checkout() {
  if [[ $# -gt 0 ]]; then
    git checkout "$@"
    return
  fi

  local branch
  branch=$(git branch --all \
    | sed 's/^[* ] //' \
    | fzf \
        --prompt="🌿 Branch > " \
        --preview 'git log --oneline --graph --decorate --color=always -n 20 {}'
  ) || return

  # Handle remote branches properly
  if [[ "$branch" == remotes/* ]]; then
    local clean_branch=${branch#remotes/origin/}
    git checkout -t "origin/$clean_branch"
  else
    git checkout "$branch"
  fi
}

# An enhancement version of git log
_git_log() {
  git log --oneline --graph --decorate --color=always \
  | fzf --ansi \
        --preview 'git show --color=always $(echo {} | awk "{print \$1}")'
}

# Initialize git repository and push to new remote repository
# Input: $1 - GitHub repository URL
# Output: Initializes git, commits all files, and pushes to remote repository
_git_push_new() {
  if [ -z "$1" ]; then
    echo "Usage: gitpushnew <github-repo-url>";
    return 1;
  fi;
  git init &&
  git add . &&
  git commit -m "Initial commit" &&
  git branch -M main &&
  git remote add origin "$1" &&
  git pull origin main &&
  git push -u origin main || echo "Push failed. Possibly due to conflicts or no upstream branch.";
}

_home() {
  clear
  cd "$HOME" || return
}

_proj() {
  clear
  cd "$HOME/projects" || return
}

# Initialize a new Vite project with customizable template
# Input: $1 - folder name (optional, defaults to current directory), $2 - template (optional, defaults to 'vue-ts')
# Output: Creates new Vite project with specified template
_init_vite() {
  #-- set the folder name to the first parameter or the current directory if not provided
  local folder=${1:-.}

  #-- set the template to the second parameter or default to 'vue-ts'
  local template=${2:-vue-ts}

  npm create vite@latest "$folder" -- --template "$template"
}

# Create directory and navigate into it
# Input: $1 - directory name/path to create
# Output: Creates directory and changes current working directory to it
_makedir() {
    mkdir -p "$1" && cd "$1";
}

# Display version information for installed development tools and languages
# Input: None
# Output: Formatted list of installed tools with their versions or 'Not installed' status
_versions() {
    print_version() {
        local name=$1
        local cmd=$2
        local version_output

        if command -v ${cmd%% *} >/dev/null 2>&1; then
            version_output=$(eval "$cmd" 2>/dev/null)
            version_output=$(echo "$version_output" | head -n 1)
            printf "%-15s: %s\n" "$name" "$version_output"
        else
            printf "%-15s: %s\n" "$name" "Not installed"
        fi
    }

    echo "=== Development Tools ==="
    print_version "Angular" "ng --version"
    print_version "Bun" "bun -v"
    print_version "Git" "git --version"
    print_version "Go" "go version"
    print_version "PNPM" "pnpm -v"			
    print_version "NVM" "nvm -v"
    print_version "NPM" "npm -v"
    print_version "Node.js" "node -v"
    print_version "Python" "python3 --version"
    print_version "Redis CLI" "redis-cli --version"
    print_version "Ruby" "ruby -v"
    print_version "Rust" "rustc --version"

    echo
    echo "=== Tools for Mobile Development ==="
    print_version "ADB" "adb version"
    print_version "Cocoapods" "pod --version"
    print_version "Ionic" "ionic --version"
    print_version "React Native" "npm view react-native version"

    echo
    echo "=== PHP Development Tools ==="
    print_version "Composer" "composer --version"

    echo
    echo "=== AI CLI ==="
    print_version "Claude" "claude --version"
    print_version "Copilot" "copilot -v"
    print_version "Gemini" "gemini --v"
    print_version "Ollama" "ollama --version"
    print_version "AI Chat" "aichat --version"

    echo
    echo "=== System & Others ==="
    print_version "Starship" "starship --version"
    print_version "Zinit" "zinit version"
    print_version "Btop" "btop --version"
    print_version "Fzf" "fzf --version"
    print_version "Navi" "navi --version"
    print_version "UV" "uv --version"
}

zle -N _alias_search  # Register as a ZLE widget
bindkey '^a' _alias_search  # Bind to Ctrl+A


# Startup benchmarking for zsh shell
_zbench() {
  local total=0
  local runs=5

  for i in {1..5}; do
    local t=$(/usr/bin/time -f "%e" zsh -i -c exit 2>&1)
    echo "Run $i: ${t}s"
    total=$(awk "BEGIN {print $total + $t}")
  done

  echo "Average: $(awk "BEGIN {print $total / $runs}")s"
}

### The beginning of AI Custom Functions ###
# Execute Claude AI with shell context and custom task
# Input: $* - task description to pass to Claude
# Output: Runs Claude with shell context file reference and specified task
claude_sh() {
  export TASK="$*"
  CONTEXT="~/.zsh/.ai_context/shell_context.md"

  claude "Use file as reference: $CONTEXT, do: '$TASK'"
}


# Execute Claude AI with task for summarizing an article
# Input: $* - task description to pass to Claude
# Output: Runs Claude with shell context file reference and specified task
claude_sums() {
  export TASK="$*"
  CONTEXT="~/.zsh/.ai_context/article_context.md"

  claude "Use file as reference: $CONTEXT, do: '$TASK'"
}

# Execute Gemini AI with shell context and custom task
# Input: $* - task description to pass to Gemini
# Output: Runs Gemini with shell context file reference and specified task
gemini_sh() {
  local TASK="$*"
  local CONTEXT="$HOME/.zsh/.ai_context/shell_context.md"

  gemini -p "Use file as reference: $CONTEXT, do: '$TASK'"
}
